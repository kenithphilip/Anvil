# Supabase project (https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-20250514
ANTHROPIC_MODEL_PREFLIGHT=claude-haiku-4-5-20251001
ANTHROPIC_BETA_HEADER=

# Tally bridge (optional, only when on a network that can reach a Tally HTTP listener)
TALLY_BRIDGE_URL=http://localhost:9000
TALLY_BRIDGE_TOKEN=

# CORS allowlist (comma separated). Use * for development only.
ALLOWED_ORIGINS=*

# Anonymous tenant default for the legacy single-file HTML to keep working without auth
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
ALLOW_ANONYMOUS_TENANT=true

# Mistral OCR (server-side OCR with bbox provenance)
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest

# FX provider (Frankfurter is keyless and free; replace if you need higher SLAs)
FX_PROVIDER_URL=https://api.frankfurter.app

# Vercel cron secret (optional). When set, /api/fx/cron requires Authorization: Bearer <secret>
CRON_SECRET=

# Inbound email (SendGrid/Mailgun/Postmark webhook auth)
EMAIL_INBOUND_TOKEN=

# Magic-link redirect URL (where users land after clicking the email link)
MAGIC_LINK_REDIRECT_URL=https://YOUR-APP-URL/auth/callback.html
