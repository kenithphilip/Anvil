# =============================================================================
# Anvil environment variables (annotated)
# Copy to .env.local for local dev. Set the same names + values in Vercel:
#   Vercel project -> Settings -> Environment Variables.
# Required vars are marked [required]; the app refuses to boot without them.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase  [required]
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Default tenant the app falls back to when no auth context is present.
# Migration 001 seeds this UUID. Override only if you renamed the row.
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
ALLOW_ANONYMOUS_TENANT=true

# Magic-link return URL. After the user clicks the email link, Supabase
# bounces here with the access_token in the hash.
MAGIC_LINK_REDIRECT_URL=https://YOUR-APP-URL/auth/callback.html

# Public origin of the deployed frontend. WebAuthn passkeys are bound to
# this exact origin: a passkey registered against one origin won't work
# on another. Also used as the redirect target for password-reset emails
# (the reset email links to <APP_URL>/#/reset).
APP_URL=http://localhost:5173

# Approval gate. Default ON. When true (the production setting),
# new signups land in tenant_members.status='pending' and an admin must
# approve from Admin Center -> Access requests. The first user on a
# fresh tenant is auto-promoted to admin so the loop can ever start.
# Set false ONLY for a dev environment where you want zero-friction
# self-service signup.
REQUIRE_APPROVAL=true

# Public signup endpoint. Default true. Set false to disable self-serve
# signup entirely; only admin-issued invites can create accounts.
SIGNUP_ALLOWED=true

# Default role assigned to a new user's pending membership; admin can
# override on approve. One of: viewer, sales_engineer, sales_manager,
# procurement, finance.
NEW_USER_ROLE=sales_engineer

# Role for the very first user on a fresh tenant (auto-approved).
# Always 'admin' unless you have a very good reason; see _lib/tenancy.js.
FIRST_USER_ROLE=admin

# AES-256-GCM key for at-rest encryption of TOTP secrets, ERP / chat /
# voice / PLM credentials. Generate with: openssl rand -hex 32.
# Without this, the secret-encryption helpers fall back to plaintext
# storage with a [secrets] running unencrypted warning. ALWAYS SET IN
# PRODUCTION.
ANVIL_SECRETS_KEY=

# Per-email password-reset rate limit (requests per hour, sliding window).
# Throttle hits return a generic 200 (no enumeration) but get audited.
RESET_RATE_LIMIT=5

# -----------------------------------------------------------------------------
# Anthropic  [required for SO Agent extraction + reasoning]
# https://console.anthropic.com/account/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-20250514
ANTHROPIC_MODEL_PREFLIGHT=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_REASONING=claude-opus-4-5
ANTHROPIC_BETA_HEADER=

# -----------------------------------------------------------------------------
# CORS / network
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# Mistral OCR  [optional; without it, OCR routes return 500]
# https://console.mistral.ai/api-keys
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest

# -----------------------------------------------------------------------------
# ClamAV scanner  [optional]
# Run a ClamAV REST proxy and point Anvil at it. Without this,
# /api/documents/scan returns 'skipped' and only deterministic ZIP guards run.
# -----------------------------------------------------------------------------
CLAMAV_URL=
CLAMAV_TOKEN=

# -----------------------------------------------------------------------------
# Tally bridge  [optional; Tally push fails fast without this]
# -----------------------------------------------------------------------------
TALLY_BRIDGE_URL=http://localhost:9000
TALLY_BRIDGE_TOKEN=

# -----------------------------------------------------------------------------
# FX rates  [optional; defaults to keyless Frankfurter]
# -----------------------------------------------------------------------------
FX_PROVIDER_URL=https://api.frankfurter.app

# -----------------------------------------------------------------------------
# Vercel cron secret  [optional; tightens cron security]
# When set, /api/fx/cron and /api/service/amc_cron require
#   Authorization: Bearer $CRON_SECRET. Vercel injects this on scheduled runs.
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Inbound email  [optional]
# Set the same value on your email provider webhook (SendGrid / Mailgun /
# Postmark / SES).
# -----------------------------------------------------------------------------
EMAIL_INBOUND_TOKEN=

# -----------------------------------------------------------------------------
# Outbound email via SendGrid  [required in production for password reset]
# Without these, /api/auth/request_reset still works in dev and returns
# the action_link in the response body so you can copy-paste it.
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Anvil

# -----------------------------------------------------------------------------
# Communications provider  [optional]
# Generic HTTP fallback when SendGrid isn't set. Endpoint must accept
# {to, subject, body, channel} JSON. Without it, comms.send marks drafts
# as 'manual'.
# -----------------------------------------------------------------------------
COMMS_PROVIDER_URL=
COMMS_PROVIDER_TOKEN=

# -----------------------------------------------------------------------------
# GSTN e-Invoice  [optional]
# India Goods and Services Tax Network IRP API. Without it, einvoice rows
# stay in PENDING_GSTN and the operator can compose but not generate IRN.
# -----------------------------------------------------------------------------
GSTN_API_URL=
GSTN_API_KEY=
