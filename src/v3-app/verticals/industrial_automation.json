{
  "id": "industrial_automation",
  "label": "Industrial automation & motion control",
  "description": "Process + factory automation: PLCs, HMIs, VFDs, servo drives, AC + DC motors, encoders, sensors, networking gear (Profinet / EtherCAT / EtherNet-IP). Distinct from electrical wholesale (cable + breakers + lighting) because the sale is engineered, partner-driven, and the customer often expects programming + commissioning support. Heavy partner channels for Siemens / Allen-Bradley / Schneider / ABB / Mitsubishi / Omron.",
  "version": 1,
  "approval_thresholds": [
    { "level": "rep",      "min_amount": 0,        "max_amount": 100000,    "currency": "INR" },
    { "level": "manager",  "min_amount": 100000,   "max_amount": 1000000,   "currency": "INR" },
    { "level": "director", "min_amount": 1000000,  "max_amount": 8000000,   "currency": "INR" },
    { "level": "vp",       "min_amount": 8000000,  "max_amount": null,      "currency": "INR" }
  ],
  "lead_time_defaults_days": {
    "stocked_sensor":         1,
    "stocked_drive":          3,
    "imported_plc_module":    35,
    "servo_motor_kit":        45,
    "panel_build":            21,
    "engineered_to_order":    60,
    "commissioning_visit":    14
  },
  "lost_reasons": [
    "Price (competitor lower)",
    "Frame size mismatch (servo / motor)",
    "Communication protocol incompatible",
    "Firmware revision restriction",
    "Lead time too long",
    "Customer pre-engineered competitor BOM",
    "Programming hours not budgeted",
    "Panel-build slot unavailable",
    "Site-acceptance test (SAT) failed",
    "OEM-locked spare parts policy"
  ],
  "contract_types": ["spot", "engineered_project", "panel_build", "spares_program", "service_contract"],
  "item_master_examples": [
