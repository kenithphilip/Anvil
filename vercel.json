{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x",
      "memory": 512,
      "maxDuration": 30
    },
    "api/claude/messages.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    },
    "api/documents/upload.js": {
      "runtime": "nodejs20.x",
      "memory": 512,
      "maxDuration": 30
    },
    "api/documents/ocr.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    },
    "api/documents/scan.js": {
      "runtime": "nodejs20.x",
      "memory": 768,
      "maxDuration": 30
    },
    "api/master_data/graph.js": {
      "runtime": "nodejs20.x",
      "memory": 768,
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/fx/cron",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/service/amc_cron",
      "schedule": "0 5 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, x-obara-tenant" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    }
  ]
}
